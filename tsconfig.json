{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",

    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["@cloudflare/workers-types"],
    "paths": {"#/*": ["./src/*"]}
  },
  "include": ["src/**/*"]
}
